# ============================================
# Configuration du back-end PearTech
# Copiez ce fichier en ".env" et adaptez les valeurs.
# ============================================

# --- Serveur ---
PORT=3000

# --- Base de données MySQL (Laragon / HeidiSQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=peartech

# --- Sécurité (JWT) ---
# Clé secrète utilisée pour signer les tokens. À CHANGER en production.
JWT_SECRET=change_moi_avec_une_longue_phrase_secrete_aleatoire
JWT_EXPIRES_IN=2h

# --- CORS ---
# Adresse du front autorisé à appeler l'API (le site PearTech).
FRONT_URL=http://localhost:8080
